{
  "name": "nationshub-backend",
  "version": "1.0.0",
  "description": "API REST en Node.js + Express + TypeScript con Clean Architecture. Actua como puente entre el front (Next.js) y la API externa de paises/mapas (restcountries.com).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:endpoints": "ts-node-dev --transpile-only scripts/test-endpoints.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
